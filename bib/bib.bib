  issn = {1524-9042},
  doi = {10.1016/j.pmn.2023.02.006},
  urldate = {2025-02-13},
  abstract = {For over 100 years, psychophysics ..{\textdiv} the scientific study between physical stimuli and sensation ... has been successfully employed in numerous scientific and healthcare disciplines, as an objective measure of sensory phenomena. This manuscript provides an overview of fundamental psychophysical concepts, emphasizing pain and research application..{\textdiv}defining common terms, methods, and procedures.Psychophysics can provide systematic and objective measures of sensory perception that can be used by nursing scientists to explore complex, subjective phenomena..{\textdiv}such as pain perception. While there needs to be improved standardization of terms and techniques, psychophysical approaches are diverse and may be tailored to address or augment current research paradigms. The interdisciplinary nature of psychophysics..{\textdiv}like nursing..{\textdiv}provides a unique lens for understanding how our perceptions are influenced by measurable sensations. While the quest to understand human perception is far from complete, nursing science has an opportunity to contribute to pain research by using the techniques and methods available through psychophysical procedures.},
  keywords = {Evoked potentials,Pain,Perception,Psychophysics,Threshold},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/W5GRHNT3/McDaniel et al_2023_Psychophysics of Pain.pdf;/media/nico/data/nostromo/phd/Zotero/storage/JL4YE399/S1524904223000346.html}
}

