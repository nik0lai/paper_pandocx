@article{laansmaSleepQualityPostTraumatic,
  title = {Sleep {{Quality}} in {{Post-Traumatic Stress Disorder Patients During Targeted Memory}}},
  author = {Laansma, Rachel A},
  pages = {28},
  abstract = {Objective: Post-traumatic stress disorder (PTSD) is a debilitating chronic health disorder, with symptoms including intrusions, nightmares, and sleep problems. Eye movement desensitization and reprocessing (EMDR) is the current first-line treatment. Unfortunately, more than half of the patients suffering PTSD do not recover completely. Therefore, there is a strong need for successful treatment. Sleep is a crucial aspect in PTSD treatment, as traumatic memories are consolidated during sleep. Targeted memory reactivation (TMR) is a technique that can manipulate the consolidation of memories during sleep, reactivating memories by applying a cue that is linked to a learned memory. The current study readministered auditory cues during sleep, used in EMDR therapy, to enhance treatment effects. The current study aimed to 1) investigate the effect of TMR on subjective sleep quality, and 2) investigate the relationship between subjective sleep quality and macro sleep architecture during TMR. Method: 33 PTSD patients were divided into a TMR (n = 17) or No-TMR group (n = 16). Patients received one EMDR session and were monitored the following night, using polysomnography (PSG). Half of the patients received TMR cues during the up-phase of slow oscillations. The following morning, subjective sleep quality was measured using the Consensus Sleep Diary (CSD) and compared between groups. Subjective sleep quality was correlated to macro sleep architecture parameters to investigate this relationship. Results: No significant differences in subjective sleep quality were found between groups and no significant correlations were found between subjective sleep quality and macro sleep architecture. Conclusion: The current study shows that TMR can be applied safely in PTSD patients, as it did not disturb sleep quality and did not trigger nightmares.},
  langid = {english},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/MCPE44AW/Laansma - Sleep Quality in Post-Traumatic Stress Disorder Pa.pdf}
}

