@article{morganBiasesSensitivitiesGeometrical1990,
  title = {Biases and Sensitivities in Geometrical Illusions},
  author = {Morgan, M. J. and Hole, G. J. and Glennerster, A.},
  year = {1990},
  month = jan,
  journal = {Vision Research},
  series = {Optics {{Physiology}} and {{Vision}}},
  volume = {30},
  number = {11},
  pages = {1793--1810},
  issn = {0042-6989},
  doi = {10.1016/0042-6989(90)90160-M},
  urldate = {2021-08-17},
  abstract = {Psychometric functions were collected to measure biases and sensitivities in certain classical illusory configurations, such as the M{\"u}ller-Lyer. We found that sensitivities (thresholds or just noticeable differences) were generally not affected by the introduction of illusory biases, and the implications of this for theories of the illusions are discussed. Experiments on the M{\"u}ller-Lyer figure showed that the effect depends upon mis-location of the ends of the figure, rather than upon a global expansion as demanded by the size-constancy theory. A new illusion is described in which the perceived position of a dot is displaced towards the centre of a surrounding cluster of dots, even though it is deary discriminable from other members of the cluster by their colour. We argue that illusions illustrate powerful constraints upon visual processing: they arise when subjects are instructed to carry out a task to which the visual system is not adapted.},
  langid = {english},
  keywords = {Collector units,Hyperacuity,Illusions,Local sign,Orientation discrimination},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/3YCTILZ8/Morgan et al. - 1990 - Biases and sensitivities in geometrical illusions.pdf;/media/nico/data/nostromo/phd/Zotero/storage/9NZM935U/004269899090160M.html}
}

