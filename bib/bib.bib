@book{wickensElementarySignalDetection2002,
  title = {Elementary Signal Detection Theory},
  author = {Wickens, Thomas D.},
  year = {2002},
  series = {Elementary Signal Detection Theory},
  pages = {xiii, 262},
  publisher = {Oxford University Press},
  address = {New York, NY, US},
  abstract = {Signal detection theory explains the way that an observer detects a weak, uncertain, or ambiguous event or signal. It is widely applied in psychology, medicine, and other related fields. This book describes the theory, explains its mathematical basis, and shows how to use it to measure an observer's sensitivity. A final chapter contains a general discussion of the statistical treatment of detection data. This work will serve as an introduction to the most important aspects of signal detection theory, useful as a reference for researchers and as a text for both undergraduate and graduate students in courses on sensation and perception, psychophysics, cognition, and quantitative methods. (PsycINFO Database Record (c) 2016 APA, all rights reserved)},
  isbn = {978-0-19-509250-9},
  keywords = {Mathematical Modeling,Signal Detection (Perception),Statistical Probability,Theories},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/2DPNIF8F/2001-05483-000.html}
}

