  doi = {10.1016/j.cub.2020.12.004},
  urldate = {2021-04-05},
  abstract = {One function of perceptual systems is to construct and maintain a reliable representation of the environment. A useful strategy intrinsic to modern ``Bayesian'' theories of perception1, 2, 3, 4, 5, 6 is to take advantage of the relative stability of the input and use perceptual history (priors) to predict current perception. This strategy is efficient1, 2, 3, 4, 5, 6, 7 but can lead to stimuli being biased toward perceptual history, clearly revealed in a phenomenon known as serial dependence.8, 9, 10, 11, 12, 13, 14 However, it is still unclear whether serial dependence biases sensory encoding or only perceptual decisions.15,16 We leveraged on the ``surround tilt illusion''---where tilted flanking stimuli strongly bias perceived orientation---to measure its influence on the pattern of serial dependence, which is typically maximal for similar orientations of past and present stimuli.7,10 Maximal serial dependence for a neutral stimulus preceded by an illusory one occurred when the perceived, not the physical, orientations of the two stimuli matched, suggesting that the priors biasing current perception incorporate the effect of the illusion. However, maximal serial dependence of illusory stimuli induced by neutral stimuli occurred when their physical (not perceived) orientations were matched, suggesting that priors interact with incoming sensory signals before they are biased by flanking stimuli. The evidence suggests that priors are high-level constructs incorporating contextual information, which interact directly with early sensory signals, not with highly processed perceptual representations.},
  langid = {english},
  keywords = {contextual effects,feedback,optimal perception,predictive coding,serial dependence,tilt illusion},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/K6RKKXVY/Cicchini et al. - 2021 - Perceptual history propagates down to early levels.pdf;/media/nico/data/nostromo/phd/Zotero/storage/ENRZYDSH/S0960982220318248.html}
}

