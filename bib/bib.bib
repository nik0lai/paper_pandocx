@article{schollIllusoryCausalCrescents2004a,
  title = {Illusory {{Causal Crescents}}: {{Misperceived Spatial Relations Due}} to {{Perceived Causality}}},
  shorttitle = {Illusory {{Causal Crescents}}},
  author = {Scholl, Brian J and Nakayama, Ken},
