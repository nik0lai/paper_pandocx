@article{wenturaMaskedEmotionalPriming2017,
  title = {Masked Emotional Priming: {{A}} Double Dissociation between Direct and Indirect Effects Reveals Non-Conscious Processing of Emotional Information beyond Valence},
  shorttitle = {Masked Emotional Priming},
  author = {Wentura, Dirk and Rohr, Michaela and Degner, Juliane},
  year = {2017},
  month = mar,
  journal = {Consciousness and Cognition},
  volume = {49},
  pages = {203--214},
  issn = {1053-8100},
  doi = {10.1016/j.concog.2017.01.016},
  urldate = {2024-10-16},
  abstract = {We demonstrate non-conscious processing beyond valence by employing the masked emotional priming paradigm (Rohr, Degner, \& Wentura, 2012) with a stimulus-onset asynchrony (SOA) variation. Emotional faces were briefly presented and directly masked, followed by the target face, using a SOA of either 43ms or 143ms. Targets were categorized as happy, angry, fearful, or sad. With short SOA, we replicated the differentiated priming effect within the negative domain (i.e., angry differentiate from fearful/sad). A direct test of prime awareness indicated that primes could not be discriminated consciously in this condition. With long SOA, however, we did not observe the priming effect whereas the direct test indicated some degree of conscious processing. Thus, indirect effects dissociated from direct effects in our study, an indication for non-conscious processing. Thereby, the present study provides evidence for non-conscious processing of emotional information beyond a simple positive-negative differentiation.},
  keywords = {/unread,Affective priming,Automatic processing,Emotion perception,Facial expression,Non-conscious},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/SY9Z3K5Q/Wentura et al_2017_Masked emotional priming.pdf;/media/nico/data/nostromo/phd/Zotero/storage/KU64MHAE/S1053810016302641.html}
}

