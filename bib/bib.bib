@article{lamyRoleConsciousPerception2015,
  title = {The Role of Conscious Perception in Attentional Capture and Object-File Updating},
  author = {Lamy, Dominique and Alon, Limor and Carmel, Tomer and Shalev, Nir},
  year = {2015},
  journal = {Psychological Science},
  volume = {26},
  number = {1},
  pages = {48--57},
  publisher = {Sage Publications},
  address = {US},
  issn = {1467-9280},
  doi = {10.1177/0956797614556777},
  abstract = {A mental process that is independent of conscious perception should run equally well with or without it. Previous investigations of unconscious processing have seldom included this comparison: They typically demonstrated only processing without conscious perception. In the research reported here, we showed that attentional capture is largely independent of conscious perception and that updating the episodic information stored about an object is entirely contingent on conscious perception. We used a spatial-cuing paradigm, in which the cue was a color-singleton distractor rendered liminal by continuous flash suppression or brief exposure. When the cue matched the participant's attentional set, it strongly captured attention whether it was subliminal or consciously perceived. In contrast, a nonmatching cue did not capture attention but instead produced a same-location cost, which was contingent on consciously perceiving the cue. Our findings demonstrate a dissociation between attention and conscious perception and unveil an important boundary condition of object-file updating. (PsycINFO Database Record (c) 2016 APA, all rights reserved)},
  keywords = {/unread,Attentional Capture,Cues,Perception,Selective Attention,Subliminal Perception},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/XUKERZLI/Lamy et al. - 2015 - The Role of Conscious Perception in Attentional Ca.pdf;/media/nico/data/nostromo/phd/Zotero/storage/MM4Z4XMU/2015-01441-005.html}
}

