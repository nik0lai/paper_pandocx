@article{maldonadomoscosoAdaptationHandtappingAffects2020,
  title = {Adaptation to Hand-Tapping Affects Sensory Processing of Numerosity Directly: Evidence from Reaction Times and Confidence},
  shorttitle = {Adaptation to Hand-Tapping Affects Sensory Processing of Numerosity Directly},
  author = {Maldonado Moscoso, Paula A. and Cicchini, Guido M. and Arrighi, Roberto and Burr, David C.},
  year = {2020},
  month = may,
  journal = {Proceedings of the Royal Society B: Biological Sciences},
  volume = {287},
  number = {1927},
  pages = {20200801},
  publisher = {Royal Society},
  doi = {10.1098/rspb.2020.0801},
  urldate = {2021-10-21},
  abstract = {Like most perceptual attributes, the perception of numerosity is susceptible to adaptation, both to prolonged viewing of spatial arrays and to repeated motor actions such as hand-tapping. However, the possibility has been raised that adaptation may reflect response biases rather than modification of sensory processing. To disentangle these two possibilities, we studied visual and motor adaptation of numerosity perception while measuring confidence and reaction times. Both sensory and motor adaptation robustly distorted numerosity estimates, and these shifts in perceived numerosity were accompanied by similar shifts in confidence and reaction-time distributions. After adaptation, maximum uncertainty and slowest response-times occurred at the point of subjective (rather than physical) equality of the matching task, suggesting that adaptation acts directly on the sensory representation of numerosity, before the decisional processes. On the other hand, making reward response-contingent, which also caused robust shifts in the psychometric function, caused no significant shifts in confidence or reaction-time distributions. These results reinforce evidence for shared mechanisms that encode the quantity of both internally and externally generated events, and advance a useful general technique to test whether contextual effects like adaptation and serial dependence really affect sensory processing.},
  keywords = {adaptation,confidence,decision-making,numerosity perception,reaction times},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/X2AP5VKY/Maldonado Moscoso et al. - 2020 - Adaptation to hand-tapping affects sensory process.pdf}
}

