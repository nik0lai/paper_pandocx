@article{schmackStriatalDopamineMediates2021,
  title = {Striatal Dopamine Mediates Hallucination-like Perception in Mice},
  author = {Schmack, K. and Bosc, M. and Ott, T. and Sturgill, J. F. and Kepecs, A.},
  year = {2021},
