@article{bouyerPredictiveExtrapolationEffects2023,
  title = {Predictive Extrapolation Effects Can Have a Greater Impact on Visual Decisions, While Visual Adaptation Has a Greater Impact on Conscious Visual Experience},
  author = {Bouyer, Loren N. and Arnold, Derek H. and Johnston, Alan and Taubert, Jessica},
  year = {2023},
  month = oct,
  journal = {Consciousness and Cognition},
  volume = {115},
  pages = {103583},
  issn = {1053-8100},
  doi = {10.1016/j.concog.2023.103583},
  urldate = {2025-02-07},
  abstract = {Human vision is shaped by historic and by predictive processes. The lingering impact of visual adaptation, for instance, can act to exaggerate differences between past and present inputs, whereas predictive processes can promote extrapolation effects that allow us to anticipate the near future. It is unclear to what extent either of these effects manifest in changes to conscious visual experience. It is also unclear how these influences combine, when acting in concert or opposition. We had people make decisions about the sizes of inputs, and report on levels of decisional confidence. Tests were either selectively subject to size adaptation, to an extrapolation effect, or to both of these effects. When these two effects were placed in opposition, extrapolation had a greater impact on decision making. However, our data suggest the influence of extrapolation is primarily decisional, whereas size adaptation more fully manifests in changes to conscious visual awareness.},
  keywords = {/1IFC,/adaptation,/confidence,/discrimination,/read},
  file = {/media/nico/data/nostromo/phd/Zotero/storage/NGLJ46D9/Bouyer et al. - 2023 - Predictive extrapolation effects can have a greate.pdf;/media/nico/data/nostromo/phd/Zotero/storage/3TCC6449/S1053810023001204.html}
}

